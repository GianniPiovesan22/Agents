# Telegram Config
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_ALLOWED_USER_IDS="your-telegram-user-id"

# LLM Config
GROQ_API_KEY="your-groq-api-key"
GEMINI_API_KEY="your-gemini-api-key"
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_MODEL="openrouter/free"
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Database (Firebase)
FIREBASE_PROJECT_ID="your-firebase-project-id"

# Voice (ElevenLabs)
ELEVENLABS_API_KEY="your-elevenlabs-api-key"
ELEVENLABS_VOICE_ID="your-elevenlabs-voice-id"

# Google Workspace (gog CLI)
GOG_ACCOUNT="your-google-account@gmail.com"

# WhatsApp Business Cloud API
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN="your-whatsapp-verify-token"
WHATSAPP_BUSINESS_ID=""
WEBHOOK_PORT=3000

# LLM Timeouts — timeout in ms for Gemini, Groq, and OpenRouter calls (default: 30000)
LLM_TIMEOUT_MS=30000

# Terminal Sandbox — directory where file-read commands (cat, head, tail, type) are restricted to
TERMINAL_SANDBOX_DIR=./workspace

# WhatsApp Security — App Secret from Meta Developer Console (required when WhatsApp is enabled)
WHATSAPP_APP_SECRET="your-whatsapp-app-secret"

# WhatsApp Whitelist — comma-separated list of authorized phone numbers (e.g. 5491112345678,5491187654321)
# If not set, ALL WhatsApp messages are rejected
WHATSAPP_ALLOWED_NUMBERS="your-whatsapp-number"

# Semantic Memory — max embeddings stored per user in SQLite (default: 500)
MEMORY_MAX_EMBEDDINGS=500
